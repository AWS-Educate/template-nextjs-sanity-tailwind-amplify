# ═══════════════════════════════════════════════════════════════
# .gitignore - {{PROJECT_NAME}}
# ═══════════════════════════════════════════════════════════════

# ===== ENVIRONMENT VARIABLES & SECRETS =====
.env
.env.*
!.env.example
!.env.local.example
!.env.production.example
!.mcp/.env.template

# Keys and certificates
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
*.der
id_rsa
id_dsa
id_ecdsa
id_ed25519

# Credentials files
secrets.json
credentials.json

# MCP config files (contain sensitive tokens)
.mcp.json
.env.local
.claude.json

# ===== DEPENDENCIES =====
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz

# ===== NEXT.JS =====
.next/
next-env.d.ts
*.tsbuildinfo
.vercel

# ===== SANITY STUDIO =====
dist/

# ===== OS FILES =====
.DS_Store
Thumbs.db
Desktop.ini

# ===== IDE =====
# Keep .idea/, .vscode/, .copilot/, .claude/, .mcp/ folders in repo
# but ignore user-specific configs
.idea/workspace.xml
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/dictionaries
.idea/shelf/
.vscode/settings.json
.vscode/*.code-workspace
*.swp
*.swo

# ===== LOGS =====
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ===== BUILD & COVERAGE =====
build/
coverage/
*.lcov
.nyc_output

# ===== CACHE =====
.cache/
.sass-cache/

# ===== TEMP FILES =====
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig
*.rej
*~
tmp/
temp/

# ===== CLAUDE CODE =====
.claude/CLAUDE.local.md
.claude/*.local.md
.claude/debug/
.claude/cache/

# ===== MCP TEAM CONFIG =====
.mcp/.env.shared
.mcp/credentials/
