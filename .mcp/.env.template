# ============================================
# MCP API Keys - Academia Semillas Team
# ============================================
#
# INSTRUCCIONES:
# 1. Copia este archivo como `.env` en la raíz del proyecto
# 2. Pide las API keys reales al líder del equipo
# 3. NUNCA commitees el archivo .env (está en .gitignore)
#
# ============================================

# ===== SANITY CMS =====
# Content management system
# Obtener en: https://www.sanity.io/manage
SANITY_PROJECT_ID=tu_project_id_aqui
SANITY_DATASET=production
SANITY_API_TOKEN=tu_token_aqui

# ===== GITHUB =====
# Repository access (elige una de las dos opciones)

# Opción 1: Token personal (para MCP npm)
# Obtener en: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=tu_token_aqui

# Opción 2: Token MCP (para MCP HTTP API)
# Obtener en: https://github.com/settings/tokens
GITHUB_MCP_TOKEN=tu_token_aqui

# ===== SHORT.IO =====
# URL shortening service
# Obtener en: https://app.short.io/settings/integrations
SHORTIO_API_KEY=tu_api_key_aqui

# ===== GOOGLE CLOUD =====
# Google Analytics, Search Console, Tag Manager
# Project ID visible en: https://console.cloud.google.com
GOOGLE_CLOUD_PROJECT=tu_project_id_aqui

# Nota: El archivo de credenciales JSON debe estar en:
# .mcp/credentials/google-cloud.json
# (No se configura aquí, se comparte por canal seguro)

