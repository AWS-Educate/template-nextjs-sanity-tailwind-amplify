{
  "$schema": "https://modelcontextprotocol.io/schemas/mcp.json",
  "mcpServers": {
    "sanity": {
      "command": "npx",
      "args": [
        "-y",
        "@sanity/mcp-server@latest"
      ],
      "env": {
        "SANITY_PROJECT_ID": "${SANITY_PROJECT_ID}",
        "SANITY_DATASET": "${SANITY_DATASET}",
        "SANITY_API_TOKEN": "${SANITY_API_TOKEN}",
        "MCP_USER_ROLE": "editor"
      },
      "description": "Sanity CMS - Content management and queries for {{PROJECT_NAME}}",
      "required": true
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "description": "GitHub - Repository access, issues, PRs",
      "required": true
    },
    "google-search-console": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-gsc"
      ],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "${PROJECT_ROOT}/.mcp/credentials/google-cloud.json"
      },
      "description": "Google Search Console - SEO analytics and site performance",
      "required": false
    },
    "google-analytics": {
      "command": "pipx",
      "args": [
        "run",
        "analytics-mcp"
      ],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "${PROJECT_ROOT}/.mcp/credentials/google-cloud.json",
        "GOOGLE_CLOUD_PROJECT": "${GOOGLE_CLOUD_PROJECT}"
      },
      "description": "Google Analytics 4 - Web analytics and reporting",
      "required": false
    },
    "google-tag-manager": {
      "command": "pipx",
      "args": [
        "run",
        "gtm-mcp"
      ],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "${PROJECT_ROOT}/.mcp/credentials/google-cloud.json"
      },
      "description": "Google Tag Manager - Tag management and configuration",
      "required": false
    },
    "short-io": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-short"
      ],
      "env": {
        "SHORT_IO_API_KEY": "${SHORT_IO_API_KEY}",
        "SHORT_IO_DOMAIN": "${SHORT_IO_DOMAIN}"
      },
      "description": "Short.io - URL shortening and link management (optional)",
      "required": false
    }
  },
  "enabledMcpjsonServers": [
    "io.github.github/github-mcp-server"
  ]
}
