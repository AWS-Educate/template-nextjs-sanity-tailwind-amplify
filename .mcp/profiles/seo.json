{
  "description": "SEO Profile - Content + Google Analytics/Search Console",
  "use_case": "SEO audits, analytics debugging, Search Console monitoring (15% of sessions)",
  "mcpServers": {
    "sanity": {
      "command": "npx",
      "args": [
        "-y",
        "@sanity/mcp-server@latest"
      ],
      "env": {
        "SANITY_PROJECT_ID": "${SANITY_PROJECT_ID}",
        "SANITY_DATASET": "${SANITY_DATASET}",
        "SANITY_API_TOKEN": "${SANITY_API_TOKEN}",
        "MCP_USER_ROLE": "editor"
      },
      "description": "Sanity CMS - Content management and queries for Academia Semillas project",
      "required": true
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "description": "GitHub - Repository access, issues, PRs (npm version)",
      "required": true
    },
    "google-search-console": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-gsc"
      ],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "${PROJECT_ROOT}/.mcp/credentials/google-cloud.json"
      },
      "description": "Google Search Console - SEO analytics and site performance",
      "required": true
    },
    "google-analytics": {
      "command": "pipx",
      "args": [
        "run",
        "analytics-mcp"
      ],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "${PROJECT_ROOT}/.mcp/credentials/google-cloud.json",
        "GOOGLE_CLOUD_PROJECT": "${GOOGLE_CLOUD_PROJECT}"
      },
      "description": "Google Analytics - Web analytics and user behavior tracking",
      "required": true
    }
  },
  "mcpjsonServers": {
    "io.github.github/github-mcp-server": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "requestInit": {
        "headers": {
          "Authorization": "Bearer ${GITHUB_MCP_TOKEN}"
        }
      },
      "description": "GitHub MCP - Official GitHub integration via HTTP API",
      "required": false,
      "note": "Alternative to npm github. Enable only one GitHub MCP."
    }
  },
  "metadata": {
    "profile": "seo",
    "tools_count": 4,
    "estimated_tokens": 29225,
    "startup_time_ms": 3200,
    "daily_cost_usd": 1.86,
    "note": "Requires Google Cloud credentials in .mcp/credentials/google-cloud.json"
  }
}
