# =============================================================================
# Environment Variables - Next.js App
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# =============================================================================

# ===== SANITY CMS =====
NEXT_PUBLIC_SANITY_PROJECT_ID={{SANITY_PROJECT_ID}}
NEXT_PUBLIC_SANITY_DATASET={{SANITY_DATASET}}
SANITY_API_READ_TOKEN={{SANITY_READ_TOKEN}}
SANITY_API_WRITE_TOKEN={{SANITY_WRITE_TOKEN}}

# ===== ANALYTICS =====
NEXT_PUBLIC_GA4_ID={{GA4_ID}}
NEXT_PUBLIC_SEGMENT_WRITE_KEY={{SEGMENT_WRITE_KEY}}

# ===== AUTHENTICATION (better-auth + Turso) =====
BETTER_AUTH_SECRET={{BETTER_AUTH_SECRET}}
TURSO_DATABASE_URL={{TURSO_DATABASE_URL}}
TURSO_AUTH_TOKEN={{TURSO_AUTH_TOKEN}}

# ===== SITE CONFIG =====
NEXT_PUBLIC_SITE_URL={{SITE_URL}}
NEXT_PUBLIC_SITE_NAME={{PROJECT_NAME}}
